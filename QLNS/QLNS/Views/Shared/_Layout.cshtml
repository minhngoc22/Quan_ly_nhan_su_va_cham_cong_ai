<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - QLNS</title>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css?v=@DateTime.Now.Ticks"  />
    <link rel="stylesheet" href="~/css/home/home_css.css" />
    <link rel="stylesheet" href="~/css/chamcong/chamcong_css.css" />
    <link rel="stylesheet" href="~/css/chamcong/print_css.css" />
    <link rel="stylesheet" href="~/css/baocao/report_css.css" />
    <link rel="stylesheet" href="~/css/nv/employee.css" />
    <link rel="stylesheet" href="~/css/nv/profile.css" />
    <link rel="stylesheet" href="~/css/phongban.css?v=@DateTime.Now.Ticks" />
    <link rel="stylesheet" href="~/css/nguoidung.css?v=@DateTime.Now.Ticks" />
    <!-- 🔥 CSS lịch làm – PHẢI ĐỂ CUỐI -->
    <link rel="stylesheet" href="~/css/lichlam/lichlam_css.css?v=@DateTime.Now.Ticks" />
</head>

<body>
    <div class="app-container">

        @* ================== HIỆN KHI ĐÃ LOGIN ================== *@
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <!-- SIDEBAR -->
            <aside class="sidebar">
                <h2 class="sidebar-title">Company Attendance</h2>

                <nav class="menu">


                    @* ===== ADMIN ===== *@
                    @if (User.IsInRole("Admin"))
                    {
                        <!-- 1. DASHBOARD (THỐNG KÊ HOME) -->
                        <a asp-controller="Admins" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Admin"?"active":"")">
                            Bảng điều khiển
                        </a>

                        <!-- 2. QUẢN LÝ PHÒNG BAN -->
                        <a asp-controller="Departments" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Department"?"active":"")">
                            Quản lý phòng ban
                        </a>

                        <!-- 3. TÀI KHOẢN & PHÂN QUYỀN -->
                        <a asp-controller="Users" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Users"?"active":"")">
                            Tài khoản & phân quyền
                        </a>

                        <!-- 4. CHẤM CÔNG & LỊCH LÀM -->
                        <a asp-controller="Shifts" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Shifts"?"active":"")">
                            Quản lý ca làm
                        </a>

                        <!-- 5. AI & CAMERA AN NINH -->
                        <a asp-controller="AdminReports" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="AdminReports"?"active":"")">
                            Thống kế và báo cáo
                        </a>
                    }              
                    
                    
                    @if (User.IsInRole("HR"))

                    {
                           <!-- DASHBOARD -->
                    <a asp-controller="Home" asp-action="Index"
                       class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")">
                            Bảng điều khiển
                    </a>

                        <a asp-controller="Employees" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Employees"?"active":"")">
                            Quản lý nhân viên
                        </a>

                        <a asp-controller="Attendance" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Attendance"?"active":"")">
                            Quản lý chấm công
                        </a>

                        <a asp-controller="Schedule" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Schedule"?"active":"")">
                            Quản lý lịch làm
                        </a>

                       
                        <a asp-controller="Report" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Report"?"active":"")">
                            Báo cáo
                        </a>
                    }

                    @* ===== STAFF ===== *@
                    @if (User.IsInRole("Employee"))
                    {
                        <a asp-controller="Staff" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Staff"?"active":"")">
                            Trang cá nhân
                        </a>

                        @* <a asp-controller="Attendance" asp-action="Index"
                           class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Attendance"?"active":"")">
                            Chấm công của tôi
                        </a> *@

                        <a asp-controller="Staff" asp-action="MySchedule"
                           class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString()=="MySchedule" ? "active" : "")">
                            Lịch làm việc
                        </a>


                        <a asp-controller="Staff" asp-action="Profile"
                           class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString()=="Profile"?"active":"")">
                            Hồ sơ cá nhân
                        </a>

                       
                    }

                </nav>
            </aside>
        }

        <!-- ================== MAIN AREA ================== -->
        <div class="main-area">

            @* ================== TOPBAR ================== *@
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <header class="topbar">
                    <span class="logo">QLNS</span>

                    <div class="topbar-right user-menu">
                        <span class="username">
                            Xin chào, <b>@User.Identity.Name</b>
                            <span class="ms-2 badge bg-secondary">
                                @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                            </span>
                        </span>

                        <div class="avatar-wrapper" onclick="toggleUserMenu()">
                            <div class="user-avatar">
                                @User.Identity.Name.Substring(0, 1)
                            </div>
                        </div>

                        <!--   =====ĐĂNG XUẤT ==========-->
                        <form id="logoutForm" asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="button"
                                    class="dropdown-item logout-btn"
                                    onclick="confirmLogout()">
                                🚪 Đăng xuất
                            </button>
                        </form>

                    </div>
                </header>
            }

            <!-- ================== CONTENT ================== -->
            <main class="content">
                @RenderBody()
                @RenderSection("Scripts", required: false)
            </main>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <footer class="footer text-muted text-center ">
                    © @DateTime.Now.Year - NgTi - AIHR
                </footer>
            }
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleUserMenu() {
            document.getElementById("userDropdown")?.classList.toggle("show");
        }

        document.addEventListener("click", function (e) {
            const menu = document.querySelector(".user-menu");
            const dropdown = document.getElementById("userDropdown");

            if (menu && dropdown && !menu.contains(e.target)) {
                dropdown.classList.remove("show");
            }
        });
    </script>

    <script>
        function confirmLogout() {
            Swal.fire({
                title: 'Đăng xuất?',
                text: 'Bạn có chắc muốn đăng xuất khỏi hệ thống không?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Đăng xuất',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logoutForm').submit();
                }
            });
        }
    </script>

</body>
</html>